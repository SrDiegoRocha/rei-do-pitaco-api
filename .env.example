# Modelo do .env — copie para .env e preencha. NUNCA commite o .env real.
#   Copy-Item .env.example .env

# ─── Dev local (docker-compose.yml sobe o Postgres) ─────────────────────────
POSTGRES_DB=reidopitaco
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# ─── Producao self-host (docker-compose.selfhost.yml + Cloudflare Tunnel) ───
# Banco (Neon) — host direto (sem -pooler), com sslmode=require
DB_URL=jdbc:postgresql://ep-SEU-HOST.sa-east-1.aws.neon.tech/neondb?sslmode=require
DB_USERNAME=neondb_owner
DB_PASSWORD=troque-aqui

# Chave de assinatura dos JWTs (>= 32 chars; gere com um gerador criptografico)
JWT_SECRET=troque-aqui

# Origens liberadas no CORS (front em producao + ambientes locais)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000,https://rei-do-pitaco.pages.dev,https://*.rei-do-pitaco.pages.dev
